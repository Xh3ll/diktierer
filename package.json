{
  "name": "diktierer",
  "version": "1.0.0",
  "description": "GoXLR Audio Transkriptions-App",
  "main": "dist/main.js",
  "scripts": {
    "build":   "tsc && node scripts/copy-assets.js",
    "start":   "npm run build && electron .",
    "dev":     "npm run build && electron .",
    "dist":    "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "de.sven-kadereit.diktierer",
    "productName": "Diktierer",
    "files": [
      "dist/**/*",
      "!dist/**/*.map"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Xh3ll",
      "repo": "diktierer",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Diktierer"
    },
    "asarUnpack": [
      "node_modules/@xenova/transformers/**/*.wasm",
      "node_modules/onnxruntime-node/**/*.node",
      "node_modules/onnxruntime-node/**/*.dll"
    ]
  }
}
